{
  "name": "@opentofu/middleware",
  "version": "0.1.0",
  "description": "TypeScript library for developing OpenTofu middleware",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "test": "jest",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "check": "npm run typecheck && npm run lint"
  },
  "keywords": [
    "opentofu",
    "terraform",
    "middleware",
    "json-rpc"
  ],
  "author": "OpenTofu",
  "license": "MPL-2.0",
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@types/jest": "^29.0.0",
    "@types/node": "^20.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.0.0"
  }
}